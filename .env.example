# Copiar a .env y ajustar valores. Todo lo referenciado aquí tiene un tier gratuito.

ENV=dev
LOG_LEVEL=INFO

# --- Base de datos y caché ---
POSTGRES_USER=logica
POSTGRES_PASSWORD=logica
POSTGRES_DB=logica
DATABASE_URL=postgresql+asyncpg://logica:logica@postgres:5432/logica
REDIS_URL=redis://redis:6379/0

# --- Puertos publicados al host (ajustar si ya están en uso en tu máquina) ---
POSTGRES_HOST_PORT=5434
REDIS_HOST_PORT=6381
API_HOST_PORT=8000
PISTON_HOST_PORT=2000
OLLAMA_HOST_PORT=11450
LANGFUSE_HOST_PORT=3010

# --- Autenticación ---
JWT_SECRET=change-me-in-env-please-use-a-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
INSTITUTION_EMAIL_DOMAINS=["inem.edu.co"]

# --- Proveedores LLM (free tier) ---
# https://console.groq.com/keys
GROQ_API_KEY=
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Ollama local, sin API key
OLLAMA_BASE_URL=http://ollama:11434

# --- Observabilidad IA (Langfuse self-hosted) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# --- Sandbox de ejecución de código (Piston self-hosted) ---
SANDBOX_URL=http://piston:2000

AI_DAILY_TOKEN_BUDGET_PER_STUDENT=20000

CORS_ORIGINS=["http://localhost:5173"]

# --- Reportes exportables (Excel/PDF, Fase 8) ---
# Volumen compartido entre api y worker en docker-compose.yml; localmente
# basta con una carpeta relativa.
REPORTS_DIR=/app/reports
